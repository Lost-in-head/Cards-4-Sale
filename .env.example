# OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# eBay developer credentials
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# eBay sandbox mode (set to False for production)
EBAY_SANDBOX=True

# Mock APIs (for development)
# Set to False when you have real API credentials
USE_OPENAI_MOCK=False
USE_EBAY_MOCK=True

# Debug mode
DEBUG=False
LOG_LEVEL=INFO

# eBay business policies (required when USE_EBAY_MOCK=False)
# Obtain these from your eBay Seller Account → Account → Business Policies
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_MERCHANT_LOCATION_KEY=your-merchant-location-key
EBAY_FULFILLMENT_POLICY_ID=your-fulfillment-policy-id
EBAY_PAYMENT_POLICY_ID=your-payment-policy-id
EBAY_RETURN_POLICY_ID=your-return-policy-id

# Optional listing defaults
EBAY_DEFAULT_CATEGORY_ID=
EBAY_DEFAULT_CURRENCY=USD
EBAY_DEFAULT_QUANTITY=1
