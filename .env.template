# =============================
# eBay Listing Generator config
# =============================
# Copy this file to .env and replace placeholders when you are ready for real APIs.

# --- OpenAI ---
# Required only when USE_OPENAI_MOCK=False
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- eBay ---
# Required only when USE_EBAY_MOCK=False
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# Safety switch: keep True until go-live to ensure sandbox endpoints are used.
EBAY_SANDBOX=True

# --- Runtime toggles ---
# For quick UI testing without secrets, keep both as True.
USE_OPENAI_MOCK=True
USE_EBAY_MOCK=True

# --- App settings ---
DEBUG=True
LOG_LEVEL=INFO
