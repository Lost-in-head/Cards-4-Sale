# =============================
# eBay Listing Generator config
# =============================
# Copy this file to .env and replace placeholders when you are ready for real APIs.

# --- OpenAI ---
# Required only when USE_OPENAI_MOCK=False
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- eBay ---
# Required only when USE_EBAY_MOCK=False
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# Safety switch: keep True until go-live to ensure sandbox endpoints are used.
EBAY_SANDBOX=True

# --- Runtime toggles ---
# For quick UI testing without secrets, keep both as True.
USE_OPENAI_MOCK=True
USE_EBAY_MOCK=True

# --- App settings ---
DEBUG=True
LOG_LEVEL=INFO

# --- eBay business policies (required when USE_EBAY_MOCK=False) ---
# Obtain policy IDs from your eBay Seller Account → Account → Business Policies.
# EBAY_MARKETPLACE_ID: the eBay site to list on (e.g. EBAY_US, EBAY_GB, EBAY_DE)
EBAY_MARKETPLACE_ID=EBAY_US
# EBAY_MERCHANT_LOCATION_KEY: key created via the Inventory Location API (optional but recommended)
EBAY_MERCHANT_LOCATION_KEY=your-merchant-location-key
EBAY_FULFILLMENT_POLICY_ID=your-fulfillment-policy-id
EBAY_PAYMENT_POLICY_ID=your-payment-policy-id
EBAY_RETURN_POLICY_ID=your-return-policy-id

# --- Optional listing defaults ---
# EBAY_DEFAULT_CATEGORY_ID: eBay category ID (leave blank to let eBay infer)
EBAY_DEFAULT_CATEGORY_ID=
EBAY_DEFAULT_CURRENCY=USD
EBAY_DEFAULT_QUANTITY=1
